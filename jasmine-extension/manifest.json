{
  "manifest_version": 3,
  "name": "Jasmine Group Avcı",
  "version": "1.1.0",
  "description": "Sahibinden.com ilanlarını tek tek veya otonom robot modunda toplu olarak Jasmine Fabrikasına aktarır.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.sahibinden.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jasmine Avcı"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.sahibinden.com/*"],
      "js": ["content.js"]
    }
  ]
}
